# ─── AI Provider — choose ONE ──────────────────────────────────────────────────
# Groq (free tier, fast): https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# OpenAI (paid): https://platform.openai.com
# OPENAI_API_KEY=your_openai_key_here

# ─── Model overrides (optional) ───────────────────────────────────────────────
# TEXT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─── Web search (optional — pick one) ─────────────────────────────────────────
# Tavily: https://app.tavily.com
# TAVILY_API_KEY=your_tavily_key

# Brave Search: https://api.search.brave.com
# BRAVE_SEARCH_API_KEY=your_brave_key

# ─── Server settings ──────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:5500,https://yourdomain.com
ALLOWED_ORIGINS=*
MAX_FILE_CHARS=80000
MAX_UPLOAD_MB=20
MAX_HISTORY_TURNS=12
